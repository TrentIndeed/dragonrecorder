# ---- shared ----
# Bearer token the client uses to talk to the server. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
CAPTURE_TOKEN=

# ---- client (Windows) ----
# Base URL of the deployed server, no trailing slash
SERVER_URL=https://rec.example.com
# Absolute path to ffmpeg.exe (full build with NVENC). Leave empty to use ffmpeg from PATH.
FFMPEG_PATH=
# Whisper model name or absolute path to a local model
WHISPER_MODEL=base.en

# ---- server ----
# Directory recordings are stored in
DATA_DIR=/srv/dragonrecorder/data
# SQLite database file
DB_PATH=/srv/dragonrecorder/dragonrecorder.sqlite3
# Refuse new uploads when free disk falls below this many GB
MIN_FREE_GB=10
# Days a recording lives before the reaper deletes the file (row is kept)
RETENTION_DAYS=14

# ---- notifications ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- dashboard ----
# bcrypt hash for Caddy basicauth (generate: caddy hash-password)
DASHBOARD_BASICAUTH_HASH=
